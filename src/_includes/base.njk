<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title or site.title }}</title>
  <meta name="description" content="{{ description or excerpt or site.description }}" />

  <!-- Open Graph / social sharing -->
  <meta property="og:title" content="{{ title or site.title }}" />
  <meta property="og:description" content="{{ description or excerpt or site.description }}" />
  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:image" content="{{ (cover or site.defaultImage) | absoluteUrl(site.url) }}" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="icon" href="/assets/vetsays-logo.jpeg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <!-- ===== HEADER ===== -->
  <header class="header" id="header">
    <div class="wrap nav">
      <a href="/" class="brand">
        <img src="/assets/vetsays-logo.jpeg" alt="vetsays logo" />
        <span>vet</span><b>says</b>
      </a>
      <nav class="nav-links" id="navLinks">
        <a href="/#categories">Pet Care</a>
        <a href="/blog/">Articles</a>
        <a href="/#students">For Vet Students</a>
        <a href="/#about">About</a>
      </nav>
      <div class="nav-right">
        <form class="search" onsubmit="return false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Search pet care…" aria-label="Search" />
        </form>
        <button class="menu-toggle" id="menuToggle" aria-label="Menu">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </header>

  {{ content | safe }}

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="wrap footer-grid">
      <div>
        <a href="/" class="brand"><span>vet</span><b>says</b></a>
        <p class="about">Pet care &amp; education from a veterinarian. Helping pet parents and vet students give pets their healthiest, happiest lives.</p>
        <div class="socials">
          <a href="https://www.instagram.com/vetsays/" target="_blank" rel="noopener" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
          <a href="https://www.linkedin.com/in/rashmi-sonawane-8b68221b7" target="_blank" rel="noopener" aria-label="LinkedIn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.3c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21H9z"/></svg></a>
        </div>
      </div>
      <div>
        <h5>Pet Care</h5>
        <ul><li><a href="/#categories">Dogs</a></li><li><a href="/#categories">Cats</a></li><li><a href="/#categories">Nutrition</a></li><li><a href="/#categories">Wellness</a></li></ul>
      </div>
      <div>
        <h5>Learn</h5>
        <ul><li><a href="/blog/">Articles</a></li><li><a href="/#students">For Vet Students</a></li><li><a href="/#categories">Symptoms</a></li><li><a href="/#categories">Behavior</a></li></ul>
      </div>
      <div>
        <h5>vetsays</h5>
        <ul><li><a href="/#about">About</a></li><li><a href="/#">Contact</a></li><li><a href="/#">Privacy</a></li></ul>
      </div>
    </div>
    <div class="wrap footer-bottom">
      <span>© 2026 vetsays. All rights reserved.</span>
      <span>Made with 🐾 for pets &amp; the people who love them.</span>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
