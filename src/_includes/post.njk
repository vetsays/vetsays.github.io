---
layout: base.njk
ogType: article
---

  <article class="post">
    <div class="wrap post-head reveal">
      <a class="post-back" href="/blog/">← All articles</a>
      <span class="tag">{{ category }}</span>
      <h1>{{ title }}</h1>
      <div class="post-meta">
        {{ author or site.author }}
        <span class="dot"></span> {{ date | readableDate }}
        {% if readTime %}<span class="dot"></span> {{ readTime }}{% endif %}
      </div>
    </div>

    {% if cover %}
    <div class="wrap">
      <div class="post-cover reveal"><img src="{{ cover }}" alt="{{ title }}" /></div>
    </div>
    {% endif %}

    <div class="wrap post-body reveal">
      {{ content | safe }}
    </div>

    <div class="wrap post-foot">
      <a href="/blog/" class="btn btn-ghost">← Back to all articles</a>
    </div>
  </article>
