---
layout: base.njk
---

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy reveal">
        <span class="eyebrow">🩺 Veterinarian-led</span>
        <h1>Pet care, <em>made simple</em> — straight from the vet.</h1>
        <p class="lead">Your go-to source for trustworthy pet care tips and education. Helping pet parents and vet students give pets their healthiest, happiest lives.</p>
        <div class="hero-cta">
          <a href="#categories" class="btn btn-primary">Explore Pet Care</a>
          <a href="#students" class="btn btn-ghost">For Vet Students 🥼</a>
        </div>
      </div>
      <div class="hero-media reveal">
        <div class="photo">
          <img src="https://images.unsplash.com/photo-1450778869180-41d0601e046e?auto=format&fit=crop&w=900&q=80" alt="Happy dog and cat" />
        </div>
        <div class="hero-badge b1"><span class="ico">📚</span> For pet parents &amp; students</div>
        <div class="hero-badge b2"><span class="ico">🐾</span> Trusted, vet-reviewed tips</div>
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <section class="trust">
    <div class="wrap trust-grid">
      <div class="trust-item"><span class="ico">🩺</span><div><h4>Veterinarian-led</h4><p>Guidance written and reviewed by a practicing vet.</p></div></div>
      <div class="trust-item"><span class="ico">📚</span><div><h4>Pet parents &amp; vet students</h4><p>Approachable for owners, rich enough for learners.</p></div></div>
      <div class="trust-item"><span class="ico">🥼</span><div><h4>Practical &amp; trusted</h4><p>Real-world pet care tips you can actually use.</p></div></div>
    </div>
  </section>

  <!-- ===== CATEGORIES ===== -->
  <section class="section" id="categories">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Browse by topic</span>
        <h2>Find care advice for your pet</h2>
        <p>Pick a category to explore vet-approved tips, symptoms, and wellness guides.</p>
      </div>
      <div class="cat-grid">
        <a class="cat reveal" href="#articles"><span class="emoji">🐶</span><span>Dogs</span></a>
        <a class="cat reveal" href="#articles"><span class="emoji">🐱</span><span>Cats</span></a>
        <a class="cat reveal" href="#articles"><span class="emoji">🥗</span><span>Nutrition</span></a>
        <a class="cat reveal" href="#articles"><span class="emoji">🌡️</span><span>Symptoms</span></a>
        <a class="cat reveal" href="#articles"><span class="emoji">💚</span><span>Wellness</span></a>
        <a class="cat reveal" href="#articles"><span class="emoji">🦴</span><span>Behavior</span></a>
      </div>
    </div>
  </section>

  <!-- ===== ARTICLES ===== -->
  <section class="section articles" id="articles">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">From the blog</span>
        <h2>Featured pet care reads</h2>
        <p>Fresh, practical articles to help you care for the pets you love.</p>
      </div>
      <div class="card-grid">
        {% for post in collections.posts | limit(6) %}
        <a class="card reveal" href="{{ post.url }}">
          <div class="thumb"><img src="{{ post.data.cover }}" alt="{{ post.data.title }}" /></div>
          <div class="body">
            <span class="tag">{{ post.data.category }}</span>
            <h3>{{ post.data.title }}</h3>
            <p>{{ post.data.excerpt }}</p>
            <div class="meta">{{ post.data.author }} <span class="dot"></span> {{ post.data.readTime }}</div>
          </div>
        </a>
        {% endfor %}
      </div>
      {% if collections.posts | length > 6 %}
      <div class="articles-more reveal">
        <a href="/blog/" class="btn btn-ghost">Browse all articles →</a>
      </div>
      {% endif %}
    </div>
  </section>

  <!-- ===== FOR VET STUDENTS ===== -->
  <section class="section" id="students">
    <div class="wrap students-solo">
      <div class="students reveal">
        <span class="eyebrow">🥼 For vet students</span>
        <h2>Learning to be a vet? We've got your back.</h2>
        <p>Clear, exam-ready breakdowns of the topics that trip students up — written by someone who's been there.</p>
        <ul class="list">
          <li><span class="check">✓</span> Plain-language notes on tricky clinical concepts</li>
          <li><span class="check">✓</span> Real case-style examples you can learn from</li>
          <li><span class="check">✓</span> Tips that bridge the gap between textbook and clinic</li>
        </ul>
        <a href="/blog/" class="btn btn-primary">Browse student resources</a>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section class="section about" id="about">
    <div class="wrap about-grid">
      <div class="about-media reveal">
        <img src="/assets/doctor-self.jpeg" alt="Dr. Rashmi Sonawane, veterinarian" />
        <a href="https://www.linkedin.com/in/rashmi-sonawane-8b68221b7" target="_blank" rel="noopener" class="about-linkedin">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.3c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21H9z"/></svg>
          Connect on LinkedIn
        </a>
      </div>
      <div class="about-copy reveal">
        <span class="eyebrow">About me</span>
        <h2>Dr. Rashmi Sonawane</h2>
        <p class="about-role">Veterinarian 🩺 · Pet care educator 📚</p>
        <p>Hi! I'm a practicing veterinarian on a mission to make trustworthy pet care simple and accessible. Through vetsays, I share practical, vet-reviewed tips for pet parents and clear, exam-ready guidance for vet students — bridging the gap between the textbook and the real-world clinic.</p>
        <div class="creds">
          <div class="cred">
            <div class="cred-head"><span class="cred-ico">🎓</span><h4>Education</h4></div>
            <ul>
              <li><strong>BVSc &amp; AH</strong> (Veterinary Science &amp; Animal Husbandry) — Bombay Veterinary College, Mumbai · 2019–2025</li>
              <li><strong>MAFSU</strong> (Maharashtra Animal &amp; Fishery Sciences University), Nagpur</li>
            </ul>
          </div>
          <div class="cred">
            <div class="cred-head"><span class="cred-ico">🥼</span><h4>Experience</h4></div>
            <ul>
              <li><strong>Veterinarian</strong> — Worldwide Veterinary Service</li>
              <li><strong>Veterinarian</strong> — Posh Pets</li>
              <li><strong>Intern</strong> — WRTC Wildlife Research &amp; Treatment Institute, Nagpur</li>
              <li><strong>Student Member</strong> — In Defense of Animals &amp; IVSA India</li>
            </ul>
          </div>
          <div class="cred">
            <div class="cred-head"><span class="cred-ico">📜</span><h4>Certifications &amp; skills</h4></div>
            <ul>
              <li>The Protein Transition: The Science Behind Alternative Proteins — The Good Food Institute · 2024</li>
              <li>Veterinary Medicine · Good Laboratory Practice (GLP)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
